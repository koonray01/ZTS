{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-trading-lab.local/schemas/codex_job.schema.json",
  "title": "Codex Job Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "job_type",
    "skill_id",
    "skill_version",
    "snapshot_id",
    "priority",
    "reason_codes",
    "input_refs",
    "token_budget",
    "allowed_tools",
    "prohibited_actions",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "job_id": {
      "type": "string"
    },
    "job_type": {
      "enum": [
        "MARKET_UPDATE",
        "ENTRY_REVIEW",
        "PART3_REVIEW",
        "EVIDENCE_AUDIT"
      ]
    },
    "skill_id": {
      "type": "string"
    },
    "skill_version": {
      "type": "string"
    },
    "snapshot_id": {
      "type": "string"
    },
    "priority": {
      "enum": [
        "LOW",
        "NORMAL",
        "HIGH",
        "CRITICAL"
      ]
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "input_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "token_budget": {
      "type": "integer",
      "minimum": 128,
      "maximum": 20000
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prohibited_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}