{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-trading-lab.local/schemas/manual_execution_proposal.schema.json",
  "title": "Manual Execution Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proposal_id",
    "decision_id",
    "decision_hash",
    "snapshot_id",
    "candidate_id",
    "symbol",
    "side",
    "entry_range",
    "stop",
    "targets",
    "expires_at",
    "manual_confirmation_required",
    "auto_execution_enabled",
    "warnings",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "proposal_id": {
      "type": "string"
    },
    "decision_id": {
      "type": "string"
    },
    "decision_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "snapshot_id": {
      "type": "string"
    },
    "candidate_id": {
      "type": "string"
    },
    "symbol": {
      "type": "string"
    },
    "side": {
      "enum": [
        "BUY",
        "SELL"
      ]
    },
    "entry_range": {
      "type": "object",
      "required": [
        "lower",
        "upper"
      ],
      "properties": {
        "lower": {
          "type": "number"
        },
        "upper": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "stop": {
      "type": "number"
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "number"
      }
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "manual_confirmation_required": {
      "const": true
    },
    "auto_execution_enabled": {
      "const": false
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}