{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-trading-lab.local/schemas/analysis_performance_report.schema.json",
  "type": "object",
  "required": ["schema_version", "cohort_filter", "directional", "scenario", "setup", "abstention", "claims", "safety"],
  "properties": {
    "schema_version": {"const": "ANALYSIS_PERFORMANCE_REPORT_V0_1"},
    "cohort_filter": {"type": "object"},
    "directional": {"type": "object"},
    "scenario": {"type": "object"},
    "setup": {
      "type": "object",
      "required": [
        "raw_variant_count", "unique_opportunity_count", "triggered_count",
        "headline_status", "expectancy_r", "representatives", "cohorts",
        "strictness_cohorts", "variant_cohorts"
      ],
      "properties": {
        "raw_variant_count": {"type": "integer", "minimum": 0},
        "unique_opportunity_count": {"type": "integer", "minimum": 0},
        "triggered_count": {"type": "integer", "minimum": 0},
        "headline_status": {"enum": ["INSUFFICIENT_EVIDENCE", "DESCRIPTIVE_ONLY"]},
        "expectancy_r": {"type": ["number", "null"]},
        "representatives": {"type": "array", "items": {"type": "object"}},
        "cohorts": {"type": "object"},
        "strictness_cohorts": {"type": "object"},
        "variant_cohorts": {"type": "object"}
      },
      "additionalProperties": false
    },
    "abstention": {"type": "object"},
    "claims": {
      "type": "object",
      "properties": {"validated_edge": {"const": false}, "promotion_gate_open": {"const": false}, "policy_tuned": {"const": false}},
      "required": ["validated_edge", "promotion_gate_open", "policy_tuned"],
      "additionalProperties": false
    },
    "safety": {"type": "object"}
  },
  "additionalProperties": false
}
