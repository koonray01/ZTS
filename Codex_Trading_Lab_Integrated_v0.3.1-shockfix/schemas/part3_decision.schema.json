{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-trading-lab.local/schemas/part3_decision.schema.json",
  "title": "Part 3 Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "decision_id",
    "decision_hash",
    "run_id",
    "snapshot_id",
    "candidate_id",
    "symbol",
    "decision",
    "execution_scope",
    "issued_at",
    "expires_at",
    "policy_version",
    "gates",
    "failed_gates",
    "pending_gates",
    "prohibited_actions",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "decision_id": {
      "type": "string",
      "minLength": 3
    },
    "decision_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "run_id": {
      "type": "string"
    },
    "snapshot_id": {
      "type": "string"
    },
    "candidate_id": {
      "type": "string"
    },
    "symbol": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "APPROVED",
        "WAIT",
        "REJECTED",
        "INVALIDATED"
      ]
    },
    "execution_scope": {
      "const": "MANUAL_ONLY"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "policy_version": {
      "type": "string"
    },
    "account_context_id": {
      "type": "string"
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "gate_id",
          "status",
          "message",
          "blocking",
          "evidence_refs"
        ],
        "properties": {
          "gate_id": {
            "type": "string"
          },
          "status": {
            "enum": [
              "PASS",
              "WAIT",
              "FAIL",
              "INVALID"
            ]
          },
          "message": {
            "type": "string"
          },
          "blocking": {
            "type": "boolean"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "failed_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pending_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "what_to_wait_for": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prohibited_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}