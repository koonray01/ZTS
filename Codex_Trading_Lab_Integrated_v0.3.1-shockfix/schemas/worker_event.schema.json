{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-trading-lab.local/schemas/worker_event.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "sequence",
    "event_id",
    "event_type",
    "job_id",
    "payload",
    "created_at",
    "previous_event_hash",
    "event_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "enum": [
        "JOB_ENQUEUED",
        "JOB_LEASED",
        "JOB_STARTED",
        "JOB_HEARTBEAT",
        "JOB_RETRY_WAIT",
        "JOB_SUCCEEDED",
        "JOB_DEAD_LETTER",
        "JOB_CANCELLED",
        "LEASE_EXPIRED"
      ]
    },
    "job_id": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "previous_event_hash": {
      "type": "string"
    },
    "event_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}