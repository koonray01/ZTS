{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-trading-lab.local/schemas/learning_report.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "stream",
    "episodes_processed",
    "failure_counts",
    "observations_created",
    "hypotheses_created",
    "promotion_candidates",
    "edge_status",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "report_id": {
      "type": "string"
    },
    "stream": {
      "enum": [
        "REPLAY",
        "LIVE_SHADOW",
        "LIVE_EXECUTION"
      ]
    },
    "episodes_processed": {
      "type": "integer",
      "minimum": 0
    },
    "failure_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "observations_created": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hypotheses_created": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "promotion_candidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "edge_status": {
      "enum": [
        "UNKNOWN",
        "INSUFFICIENT_EVIDENCE",
        "PROMISING",
        "INCONCLUSIVE",
        "REJECTED"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}