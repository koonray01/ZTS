{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-trading-lab.local/schemas/pending_plan.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "candidate_id",
    "snapshot_id",
    "symbol",
    "side",
    "entry_range",
    "invalidation",
    "expires_at",
    "status",
    "manual_only",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "plan_id": {
      "type": "string"
    },
    "candidate_id": {
      "type": "string"
    },
    "snapshot_id": {
      "type": "string"
    },
    "symbol": {
      "type": "string"
    },
    "side": {
      "enum": [
        "BUY",
        "SELL"
      ]
    },
    "entry_range": {
      "type": "object",
      "required": [
        "lower",
        "upper"
      ],
      "properties": {
        "lower": {
          "type": "number"
        },
        "upper": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "invalidation": {
      "type": "number"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "ACTIVE",
        "WINDOW_OPEN",
        "FILLED_OBSERVED",
        "CANCEL_RECOMMENDED",
        "INVALIDATED",
        "EXPIRED"
      ]
    },
    "manual_only": {
      "const": true
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}