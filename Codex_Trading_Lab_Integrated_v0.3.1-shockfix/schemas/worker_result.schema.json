{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-trading-lab.local/schemas/worker_result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "result_id",
    "job_id",
    "job_type",
    "skill_id",
    "skill_version",
    "snapshot_id",
    "status",
    "summary",
    "facts",
    "interpretations",
    "unknowns",
    "recommended_next_action",
    "permission_claim",
    "tool_trace_ids",
    "usage",
    "provider_id",
    "generated_at",
    "auto_execution_enabled"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "result_id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "job_type": {
      "enum": [
        "MARKET_UPDATE",
        "ENTRY_REVIEW",
        "PART3_REVIEW",
        "EVIDENCE_AUDIT"
      ]
    },
    "skill_id": {
      "type": "string"
    },
    "skill_version": {
      "type": "string"
    },
    "snapshot_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "SUCCEEDED",
        "FAILED"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim",
          "evidence_refs"
        ],
        "properties": {
          "claim": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "interpretations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim",
          "evidence_refs"
        ],
        "properties": {
          "claim": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_next_action": {
      "enum": [
        "NONE",
        "WAIT",
        "REQUEST_PART3",
        "MANUAL_REVIEW",
        "EVIDENCE_AUDIT"
      ]
    },
    "permission_claim": {
      "enum": [
        "NOT_EVALUATED",
        "WAIT",
        "APPROVED",
        "REJECTED",
        "INVALIDATED"
      ]
    },
    "tool_trace_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "properties": {
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "provider_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "auto_execution_enabled": {
      "const": false
    }
  }
}