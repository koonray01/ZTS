{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-trading-lab.local/schemas/canonical_policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "version",
    "status",
    "content",
    "approved_by_human",
    "approved_at",
    "source_refs",
    "dependencies",
    "policy_hash"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1.0"
    },
    "policy_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "enum": [
        "LOCKED",
        "DEPRECATED"
      ]
    },
    "content": {
      "type": "object"
    },
    "approved_by_human": {
      "const": true
    },
    "approved_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "object"
    },
    "policy_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}