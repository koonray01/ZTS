{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-trading-lab.local/schemas/candidate_readiness.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "snapshots_analyzed", "readiness", "ready_candidate_count", "snapshots_with_ready_candidate", "status_counts", "side_counts", "entry_type_counts", "trigger_status_counts", "missing_condition_counts", "hard_requirement_counts", "location_requirement_counts", "scenario_status_counts", "scenario_event_state_counts", "scenario_missing_event_counts", "execution_permission_effect", "limitations"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "mode": {"const": "READINESS_DIAGNOSTIC_QA_ONLY"},
    "snapshots_analyzed": {"type": "integer", "minimum": 0},
    "readiness": {"enum": ["READY_CANDIDATE_OBSERVED", "NO_READY_CANDIDATE"]},
    "ready_candidate_count": {"type": "integer", "minimum": 0},
    "snapshots_with_ready_candidate": {"type": "integer", "minimum": 0},
    "status_counts": {"type": "object"},
    "side_counts": {"type": "object"},
    "entry_type_counts": {"type": "object"},
    "trigger_status_counts": {"type": "object"},
    "missing_condition_counts": {"type": "object"},
    "hard_requirement_counts": {"type": "object"},
    "location_requirement_counts": {"type": "object"},
    "scenario_status_counts": {"type": "object"},
    "scenario_event_state_counts": {"type": "object"},
    "scenario_missing_event_counts": {"type": "object"},
    "execution_permission_effect": {"const": "NONE"},
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  }
}
