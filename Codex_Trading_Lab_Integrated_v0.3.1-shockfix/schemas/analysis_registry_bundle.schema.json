{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-trading-lab.local/schemas/analysis_registry_bundle.schema.json",
  "title": "Analysis Registry Ingestion Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "analysis_id", "source_class", "integrity_tier",
    "analysis", "views", "decisions", "evidence_refs"
  ],
  "properties": {
    "schema_version": {"const": "ANALYSIS_REGISTRY_BUNDLE_V0_1"},
    "analysis_id": {"type": "string", "minLength": 1},
    "source_class": {"enum": ["LIVE_MT5", "REPLAY", "SYNTHETIC", "CHAT_ONLY"]},
    "integrity_tier": {"enum": ["VERIFIED", "PARTIAL", "CHAT_ONLY", "UNMATCHED"]},
    "analysis": {"type": "object"},
    "views": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": true,
        "required": ["view_id", "system"],
        "properties": {
          "view_id": {"type": "string", "minLength": 1},
          "system": {"enum": ["ZENITH", "EXTERNAL"]}
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": true,
        "required": ["decision_id", "decision_type", "action", "scorable", "horizons"],
        "properties": {
          "decision_id": {"type": "string", "minLength": 1},
          "decision_type": {"type": "string", "minLength": 1},
          "action": {"enum": ["SETUP", "WATCH", "WAIT", "HOLD", "REJECT", "ABSTAIN"]},
          "scorable": {"type": "boolean"},
          "horizons": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "evidence_refs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}
