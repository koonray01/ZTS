{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-trading-lab.local/schemas/worker_turn.schema.json",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turn_type",
        "tool_calls",
        "usage"
      ],
      "properties": {
        "turn_type": {
          "const": "TOOL_CALLS"
        },
        "tool_calls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "tool_call_id",
              "tool_name",
              "arguments"
            ],
            "properties": {
              "tool_call_id": {
                "type": "string"
              },
              "tool_name": {
                "type": "string"
              },
              "arguments": {
                "type": "object"
              }
            }
          }
        },
        "usage": {
          "type": "object",
          "required": [
            "input_tokens",
            "output_tokens"
          ],
          "properties": {
            "input_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "output_tokens": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turn_type",
        "final",
        "usage"
      ],
      "properties": {
        "turn_type": {
          "const": "FINAL"
        },
        "final": {
          "type": "object"
        },
        "usage": {
          "type": "object",
          "required": [
            "input_tokens",
            "output_tokens"
          ],
          "properties": {
            "input_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "output_tokens": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        }
      }
    }
  ]
}